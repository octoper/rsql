{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/explicit-function-return-type": "off",
    "no-use-before-define": "off"
  },
  "ignorePatterns": ["node_modules", "lib", "dist", "coverage", "patches"]
}

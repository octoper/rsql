{
  "name": "rsql-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "RSQL compiler and parser for Node.js and Browsers",
  "repository": "https://github.com/octoper/rsql.git",
  "license": "MIT",
  "author": "Piotr Oleś <piotrek.oles@gmail.com>",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">= 22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm run build && changeset publish",
    "precommit": "lint-staged && pnpm run build && pnpm run test",
    "commit": "./node_modules/.bin/git-cz",
    "ci": "pnpm run build && pnpm run lint && pnpm run fmt:check && pnpm run test",
    "lint": "pnpm exec oxlint",
    "fmt:check": "pnpm exec oxfmt --check",
    "test": "vitest run"
  },
  "workspaces": [
    "packages/*"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && pnpm run build && pnpm run test",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,yml,json,md,html,ts}": "oxfmt"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@commitlint/config-conventional": "^8.3.4",
    "commitlint": "^8.3.5",
    "git-cz": "^4.3.1",
    "husky": "^4.2.5",
    "lint-staged": "^10.1.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "latest",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}

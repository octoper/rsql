{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "baseUrl": ".",
    "declaration": true,
    "noEmit": true,
    "paths": {
      "@resenty/rsql-ast": ["packages/ast/src"],
      "@resenty/rsql-builder": ["packages/builder/src"],
      "@resenty/rsql-emitter": ["packages/emitter/src"],
      "@resenty/rsql-parser": ["packages/parser/src"]
    }
  }
}

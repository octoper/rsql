{
  "name": "@resenty/rsql-emitter",
  "description": "RSQL Emitter",
  "repository": "https://github.com/octoper/rsql.git",
  "license": "MIT",
  "author": "octoper <me@octoper.me>",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
